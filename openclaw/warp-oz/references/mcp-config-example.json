{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "linear": {
      "command": "npx",
      "args": ["-y", "@anthropic/mcp-server-linear"],
      "env": {
        "LINEAR_API_KEY": "${LINEAR_API_KEY}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@anthropic/mcp-server-playwright"]
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    }
  },
  "_oz_notes": {
    "usage": "oz agent run --prompt '...' --mcp mcp-config.json --cwd /path/to/project",
    "cloud": "oz agent run-cloud --environment ENV_ID --prompt '...' --mcp mcp-config.json",
    "env_vars": "Set GITHUB_TOKEN and LINEAR_API_KEY in your shell. For cloud runs, store as Oz environment secrets: oz secret create --name GITHUB_TOKEN --value ghp_xxx",
    "inline": "Pass inline: --mcp '{\"mcpServers\":{\"fetch\":{\"command\":\"uvx\",\"args\":[\"mcp-server-fetch\"]}}}'",
    "repeatable": "Pass --mcp multiple times for separate config files, or combine all servers into one JSON."
  }
}
